--
-- Name: events Allow delete for event owners; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow delete for event owners" ON public.events FOR DELETE TO authenticated USING (((auth.uid())::text = creator_id));


--
-- Name: events Allow insert for authenticated users; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow insert for authenticated users" ON public.events FOR INSERT TO authenticated WITH CHECK (true);


--
-- Name: events Allow public read access; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow public read access" ON public.events FOR SELECT USING (true);


--
-- Name: events Allow select for authenticated users; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow select for authenticated users" ON public.events FOR SELECT TO authenticated USING (true);


--
-- Name: events Allow update for event owners; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow update for event owners" ON public.events FOR UPDATE TO authenticated USING (((auth.uid())::text = creator_id));


--
-- Name: attendees User can see their own tickets; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "User can see their own tickets" ON public.attendees FOR SELECT USING ((auth.uid() = user_id));


--
-- Name: events; Type: ROW SECURITY; Schema: public; Owner: postgres
--

ALTER TABLE public.events ENABLE ROW LEVEL SECURITY;

