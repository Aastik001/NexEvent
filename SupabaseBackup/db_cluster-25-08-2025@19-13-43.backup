--
-- Name: get_auth(text); Type: FUNCTION; Schema: pgbouncer; Owner: supabase_admin
--

CREATE FUNCTION pgbouncer.get_auth(p_usename text) RETURNS TABLE(username text, password text)
    LANGUAGE plpgsql SECURITY DEFINER
    AS $_$
begin
    raise debug 'PgBouncer auth request: %', p_usename;

    return query
    select 
        rolname::text, 
        case when rolvaliduntil < now() 
            then null 
            else rolpassword::text 
        end 
    from pg_authid 
    where rolname=$1 and rolcanlogin;
end;
$_$;


ALTER FUNCTION pgbouncer.get_auth(p_usename text) OWNER TO supabase_admin;

--
-- Name: create_events_table(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.create_events_table() RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  CREATE TABLE IF NOT EXISTS public.events (
    id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
    title text NOT NULL,
    description text NOT NULL,
    date text NOT NULL,
    time text NOT NULL,
    location text NOT NULL,
    organizer text NOT NULL,
    category text NOT NULL,
    imageUrl text,
    price numeric DEFAULT 0,
    attendees jsonb DEFAULT '[]'::jsonb
  );
END;
$$;


ALTER FUNCTION public.create_events_table() OWNER TO postgres;

--
-- Name: enable_rls_and_policies(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.enable_rls_and_policies() RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  ALTER TABLE public.events ENABLE ROW LEVEL SECURITY;

  -- Policy: anyone can SELECT
  IF NOT EXISTS (SELECT 1 FROM pg_policies WHERE tablename = 'events' AND policyname = 'select_policy') THEN
    CREATE POLICY select_policy ON public.events
      FOR SELECT USING (true);
  END IF;

  -- Policy: only authenticated users can INSERT
  IF NOT EXISTS (SELECT 1 FROM pg_policies WHERE tablename = 'events' AND policyname = 'insert_policy') THEN
    CREATE POLICY insert_policy ON public.events
      FOR INSERT WITH CHECK (auth.role() = 'authenticated');
  END IF;

  -- Policy: only owner can UPDATE their event
  IF NOT EXISTS (SELECT 1 FROM pg_policies WHERE tablename = 'events' AND policyname = 'update_policy') THEN
    CREATE POLICY update_policy ON public.events
      FOR UPDATE USING (auth.uid() = owner_id);
  END IF;

  -- Policy: only owner can DELETE their event
  IF NOT EXISTS (SELECT 1 FROM pg_policies WHERE tablename = 'events' AND policyname = 'delete_policy') THEN
    CREATE POLICY delete_policy ON public.events
      FOR DELETE USING (auth.uid() = owner_id);
  END IF;
END;
$$;


ALTER FUNCTION public.enable_rls_and_policies() OWNER TO postgres;

